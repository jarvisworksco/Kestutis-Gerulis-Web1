---
import { duk, imone } from '../data/site.js';
---

<!-- Pokalbių robotas su DUK atsakymais -->
<div class="fixed bottom-24 right-4 z-50 md:bottom-6 md:right-6">
  <!-- Atidarymo mygtukas -->
  <button
    id="chat-toggle"
    class="group relative flex h-16 w-16 cursor-pointer items-center justify-center rounded-full shadow-xl transition-transform duration-200 hover:scale-105"
    aria-label="Atidaryti pagalbos pokalbį"
    aria-expanded="false"
    aria-controls="chat-panel"
  >
    <span class="absolute inset-0 animate-ping rounded-full bg-brand-500/40" aria-hidden="true"></span>
    <img src="/avatar.svg" alt="" class="relative h-16 w-16 rounded-full" width="354" height="354" />
    <span class="absolute -right-0.5 -top-0.5 flex h-4 w-4 items-center justify-center rounded-full bg-accent text-[10px] font-bold text-brand-950 ring-2 ring-white" aria-hidden="true">?</span>
  </button>

  <!-- Pokalbio langas -->
  <div
    id="chat-panel"
    class="absolute bottom-20 right-0 hidden w-[calc(100vw-2rem)] max-w-sm origin-bottom-right overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-brand-100"
    role="dialog"
    aria-label="Pagalbos pokalbis"
  >
    <!-- Antraštė -->
    <div class="flex items-center gap-3 bg-brand-800 px-4 py-3.5">
      <img src="/avatar.svg" alt={imone.pavadinimas} class="h-11 w-11 rounded-full ring-2 ring-white/20" width="354" height="354" />
      <div class="min-w-0 flex-1">
        <p class="display truncate font-semibold leading-tight text-white">{imone.pavadinimas}</p>
        <p class="flex items-center gap-1.5 text-xs text-brand-100">
          <span class="inline-block h-2 w-2 shrink-0 rounded-full bg-green-400"></span>
          Greiti atsakymai
        </p>
      </div>
      <button id="chat-close" class="cursor-pointer rounded-lg p-1.5 text-white/80 transition-colors duration-200 hover:bg-white/10 hover:text-white" aria-label="Uždaryti pokalbį">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <!-- Žinutės -->
    <div id="chat-messages" class="max-h-72 space-y-3 overflow-y-auto bg-brand-50/60 px-4 py-4">
      <div class="flex gap-2">
        <img src="/avatar.svg" alt="" class="h-8 w-8 shrink-0 rounded-full" width="354" height="354" />
        <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-white px-3.5 py-2.5 text-sm leading-relaxed text-brand-900 shadow-sm">
          Sveiki! 👋 Galiu greitai atsakyti į dažniausius klausimus. Pasirinkite klausimą žemiau arba skambinkite mums tiesiogiai.
        </div>
      </div>
    </div>

    <!-- Klausimų mygtukai -->
    <div id="chat-questions" class="flex flex-wrap gap-2 border-t border-brand-100 bg-white px-4 py-3">
      {duk.map((d) => (
        <button
          class="chat-q cursor-pointer rounded-full border border-brand-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-brand-800 transition-colors duration-200 hover:border-brand-400 hover:bg-brand-50"
          data-answer={d.atsakymas}
        >
          {d.klausimas}
        </button>
      ))}
    </div>

    <!-- Skambučio raginimas -->
    <a
      href={imone.telefonasHref}
      class="flex items-center justify-center gap-2 bg-accent px-4 py-3 text-sm font-bold text-brand-950 transition-colors duration-200 hover:bg-accent-dark"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
      Skambinti: {imone.telefonas}
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById('chat-toggle');
  const panel = document.getElementById('chat-panel');
  const close = document.getElementById('chat-close');
  const messages = document.getElementById('chat-messages');
  const ping = toggle?.querySelector('.animate-ping');

  const openPanel = () => {
    panel?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    ping?.remove(); // nustojam „pulsuoti" kai jau atidaryta
    messages?.scrollTo({ top: messages.scrollHeight });
  };
  const closePanel = () => {
    panel?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  };

  toggle?.addEventListener('click', () => {
    panel?.classList.contains('hidden') ? openPanel() : closePanel();
  });
  close?.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panel?.classList.contains('hidden')) closePanel();
  });

  function bubble(text: string, who: 'user' | 'bot') {
    const row = document.createElement('div');
    row.className = who === 'user' ? 'flex justify-end' : 'flex gap-2';
    if (who === 'bot') {
      const av = document.createElement('img');
      av.src = '/avatar.svg';
      av.alt = '';
      av.className = 'h-8 w-8 shrink-0 rounded-full';
      row.appendChild(av);
    }
    const b = document.createElement('div');
    b.className =
      who === 'user'
        ? 'max-w-[80%] rounded-2xl rounded-tr-sm bg-brand-700 px-3.5 py-2.5 text-sm leading-relaxed text-white shadow-sm'
        : 'max-w-[80%] rounded-2xl rounded-tl-sm bg-white px-3.5 py-2.5 text-sm leading-relaxed text-brand-900 shadow-sm';
    b.textContent = text;
    row.appendChild(b);
    messages?.appendChild(row);
    messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
    return row;
  }

  function typing() {
    const row = document.createElement('div');
    row.className = 'flex gap-2';
    row.innerHTML =
      '<img src="/avatar.svg" alt="" class="h-8 w-8 shrink-0 rounded-full" />' +
      '<div class="flex items-center gap-1 rounded-2xl rounded-tl-sm bg-white px-4 py-3 shadow-sm">' +
      '<span class="h-2 w-2 animate-bounce rounded-full bg-brand-300" style="animation-delay:0ms"></span>' +
      '<span class="h-2 w-2 animate-bounce rounded-full bg-brand-300" style="animation-delay:150ms"></span>' +
      '<span class="h-2 w-2 animate-bounce rounded-full bg-brand-300" style="animation-delay:300ms"></span></div>';
    messages?.appendChild(row);
    messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
    return row;
  }

  document.querySelectorAll<HTMLButtonElement>('.chat-q').forEach((q) => {
    q.addEventListener('click', () => {
      const answer = q.dataset.answer || '';
      bubble(q.textContent?.trim() || '', 'user');
      const t = typing();
      setTimeout(() => {
        t.remove();
        bubble(answer, 'bot');
      }, 700);
    });
  });
</script>
