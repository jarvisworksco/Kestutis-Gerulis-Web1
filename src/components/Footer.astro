---
import { imone, paslaugos, vietoves } from '../data/site.js';
const metai = new Date().getFullYear();
---

<footer class="bg-brand-950 text-white/80">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <img src="/logo.svg" alt={`${imone.pavadinimas} logotipas`} class="h-20 w-auto" />
      <span class="sr-only">{imone.pavadinimas}</span>
      <p class="mt-4 text-sm leading-relaxed">
        {/* PAKEISTI — 1–2 sakinių įmonės aprašymas su pagrindinėmis paslaugomis ir vietove. */}
        Pagrindinės paslaugos {imone.miestas} mieste ir {imone.aptarnavimoSpindulys}. {imone.patirtisMetais} metų patirtis, profesionali įranga.
      </p>
      {imone.saskaitosFakturos && <p class="mt-3 text-sm">Išrašome sąskaitas faktūras.</p>}
    </div>

    <div>
      <h3 class="display text-sm font-semibold tracking-wider text-white">Paslaugos</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        {paslaugos.map((p) => (
          <li><a href={`/paslaugos/${p.slug}`} class="transition-colors duration-200 hover:text-accent">{p.pavadinimas}</a></li>
        ))}
        <li><a href="/galerija" class="transition-colors duration-200 hover:text-accent">Atlikti darbai</a></li>
      </ul>
    </div>

    <div>
      <h3 class="display text-sm font-semibold tracking-wider text-white">Aptarnaujamos vietovės</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        {vietoves.slice(0, 6).map((v) => <li>{v}</li>)}
        <li class="text-white/60">… {imone.aptarnavimoSpindulys}</li>
      </ul>
    </div>

    <div>
      <h3 class="display text-sm font-semibold tracking-wider text-white">Kontaktai</h3>
      <ul class="mt-4 space-y-3 text-sm">
        <li>
          <a href={imone.telefonasHref} class="flex items-center gap-2 font-semibold text-white transition-colors duration-200 hover:text-accent">
            <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
            {imone.telefonas}
          </a>
        </li>
        <li class="flex items-center gap-2">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
          {imone.miestas}, {imone.aptarnavimoSpindulys}
        </li>
        <li>
          <a href={imone.profilis} rel="noopener" target="_blank" class="inline-flex items-center gap-2 transition-colors duration-200 hover:text-accent">
            <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.783 1.401 8.168L12 19.318l-7.335 3.843 1.401-8.168L.132 9.21l8.2-1.192L12 .587z"/></svg>
            {imone.ivertinimas.toFixed(1)} ★ atsiliepimų profilis
          </a>
        </li>
      </ul>
      <a href="/kontaktai" class="mt-5 inline-block rounded-lg bg-accent px-5 py-2.5 text-sm font-bold text-brand-950 transition-colors duration-200 hover:bg-accent-dark">
        Gauti nemokamą pasiūlymą
      </a>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-3 px-4 py-5 text-xs text-white/50 sm:flex-row sm:px-6">
      <p>© {metai} {imone.pavadinimas}. Visos teisės saugomos. · Sukurta <a href="https://jarvisweb.lt" target="_blank" rel="noopener" class="font-semibold transition-colors duration-200 hover:text-white">jarvisweb.lt</a></p>
      <div class="flex gap-5">
        <a href="/privatumo-politika" class="transition-colors duration-200 hover:text-white">Privatumo politika</a>
        <a href="/taisykles" class="transition-colors duration-200 hover:text-white">Taisyklės</a>
      </div>
    </div>
  </div>
</footer>

<!-- Mobilus lipnus „Skambinti dabar" baras -->
<div class="fixed inset-x-0 bottom-0 z-40 border-t border-brand-100 bg-white/95 p-3 shadow-[0_-4px_16px_rgba(0,0,0,0.1)] backdrop-blur-md md:hidden">
  <div class="flex gap-3">
    <a href={imone.telefonasHref} class="flex flex-1 items-center justify-center gap-2 rounded-lg bg-brand-700 px-4 py-3 font-bold text-white transition-colors duration-200 hover:bg-brand-800">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
      Skambinti dabar
    </a>
    <a href="/kontaktai" class="flex flex-1 items-center justify-center rounded-lg bg-accent px-4 py-3 font-bold text-brand-950 transition-colors duration-200 hover:bg-accent-dark">
      Gauti pasiūlymą
    </a>
  </div>
</div>
<!-- Atstumas, kad mobilus baras neuždengtų turinio -->
<div class="h-20 md:hidden" aria-hidden="true"></div>
