---
import { imone } from '../data/site.js';

interface Props {
  antraste?: string;
  tekstas?: string;
}
const {
  antraste = 'Pasiruošę pradėti?',
  tekstas = 'Paskambinkite arba palikite užklausą — įvertinsiu darbą ir pateiksiu kainą be jokių įsipareigojimų.',
} = Astro.props;
---

<section class="relative overflow-hidden bg-brand-800 py-20">
  <div class="absolute inset-0 opacity-[0.07]" aria-hidden="true" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 28px 28px;"></div>
  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6" data-reveal>
    <h2 class="display text-3xl font-semibold text-white sm:text-4xl">{antraste}</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">{tekstas}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href="/kontaktai" class="w-full rounded-lg bg-accent px-8 py-4 text-lg font-bold text-brand-950 transition-colors duration-200 hover:bg-accent-dark sm:w-auto">
        Gauti nemokamą pasiūlymą
      </a>
      <a href={imone.telefonasHref} class="flex w-full items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-8 py-4 text-lg font-bold text-white transition-colors duration-200 hover:bg-white/10 sm:w-auto">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
        {imone.telefonas}
      </a>
    </div>
  </div>
</section>
