---
import SectionHeading from './SectionHeading.astro';
import { procesas } from '../data/site.js';
---

<section class="bg-brand-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <SectionHeading eyebrow="Kaip tai vyksta" title="Paprastas procesas — nuo skambučio iki rezultato" />
    <ol class="relative mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Jungiamoji linija per visus žingsnius (tik desktop) -->
      <div class="absolute left-0 right-0 top-6 hidden h-0.5 bg-gradient-to-r from-brand-200 via-brand-400 to-brand-200 lg:block" aria-hidden="true"></div>
      {procesas.map((p, i) => (
        <li class="relative rounded-2xl bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md" data-reveal style={`--d:${i * 90}ms`}>
          <div class="flex items-center justify-between">
            <span class="display relative z-10 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-700 text-xl font-bold text-white ring-4 ring-brand-50">{i + 1}</span>
            {i < procesas.length - 1 && (
              <svg class="h-6 w-6 text-brand-300 lg:hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            )}
          </div>
          <h3 class="display mt-5 text-lg font-semibold text-brand-950">{p.pavadinimas}</h3>
          <p class="mt-2 text-sm leading-relaxed text-brand-900/70">{p.aprasymas}</p>
          {i < procesas.length - 1 && (
            <svg class="absolute -right-6 top-12 z-10 hidden h-7 w-7 text-brand-400 lg:block" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>
