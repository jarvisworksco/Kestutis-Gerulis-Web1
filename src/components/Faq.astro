---
import SectionHeading from './SectionHeading.astro';
import { duk } from '../data/site.js';
---

<section class="py-20" id="duk">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <SectionHeading eyebrow="DUK" title="Dažniausiai užduodami klausimai" />
    <div class="mt-12 space-y-3">
      {duk.map((d, i) => (
        <details class="faq group rounded-xl border border-brand-100 bg-white shadow-sm" data-reveal style={`--d:${i * 60}ms`}>
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 font-semibold text-brand-950">
            {d.klausimas}
            <svg class="h-5 w-5 shrink-0 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="faq-body">
            <div>
              <p class="px-6 pb-5 leading-relaxed text-brand-900/75">{d.atsakymas}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  // Sklandus akordeono atsidarymas: <details> turinį rodo iškart, todėl
  // animuojame per .expanded klasę — atidarius palaukiame kadro, uždarant
  // pirma suskleidžiame ir tik tada nuimame open atributą.
  document.querySelectorAll<HTMLDetailsElement>('details.faq').forEach((det) => {
    const summary = det.querySelector('summary');
    const body = det.querySelector<HTMLElement>('.faq-body');
    if (!summary || !body) return;
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (det.open) {
        det.classList.remove('expanded');
        const onEnd = () => {
          det.open = false;
          body.removeEventListener('transitionend', onEnd);
        };
        body.addEventListener('transitionend', onEnd);
      } else {
        det.open = true;
        requestAnimationFrame(() => requestAnimationFrame(() => det.classList.add('expanded')));
      }
    });
  });
</script>
