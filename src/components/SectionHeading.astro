---
interface Props {
  eyebrow: string;
  title: string;
  light?: boolean;
  center?: boolean;
}
const { eyebrow, title, light = false, center = true } = Astro.props;
---

<div class={center ? 'text-center' : ''} data-reveal>
  <span class={`inline-block rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-widest ${light ? 'bg-white/10 text-accent' : 'bg-brand-100 text-brand-700'}`}>
    {eyebrow}
  </span>
  <h2 class={`display mt-4 text-3xl font-semibold sm:text-4xl ${light ? 'text-white' : 'text-brand-950'}`}>
    {title}
  </h2>
  <div class={`mt-4 h-1 w-16 rounded-full bg-accent ${center ? 'mx-auto' : ''}`} aria-hidden="true"></div>
</div>
