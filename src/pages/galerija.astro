---
import Base from '../layouts/Base.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import CtaSection from '../components/CtaSection.astro';
import { galerija, imone } from '../data/site.js';
---

<Base
  title={`Mūsų darbai — atliktų darbų galerija | ${imone.pavadinimas}`}
  description={`Atliktų darbų galerija ${imone.miestas} mieste ir ${imone.aptarnavimoSpindulys}. Nuotraukos prieš ir po.`}
>
  <section class="bg-brand-950 pb-16 pt-44">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6" data-reveal>
      <span class="inline-block rounded-full bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-accent">Galerija</span>
      <h1 class="display mt-4 text-4xl font-bold text-white sm:text-5xl">Mūsų darbai</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/75">
        Visos nuotraukos — realūs mūsų atlikti darbai {imone.miestas} mieste ir aplink. Spustelėkite nuotrauką, kad padidintumėte.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <GalleryGrid nuotraukos={galerija} />
    </div>
  </section>

  <CtaSection antraste="Norite tokio paties rezultato?" />
</Base>
