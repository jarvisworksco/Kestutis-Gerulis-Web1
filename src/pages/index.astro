---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import InquiryForm from '../components/InquiryForm.astro';
import Reviews from '../components/Reviews.astro';
import Faq from '../components/Faq.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CtaSection from '../components/CtaSection.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { imone, paslaugos, galerija, vietoves, turinys } from '../data/site.js';

const galerijosPavyzdziai = galerija.slice(0, 8);
// SEO: PAKEISTI nieko nereikia — tekstas surenkamas iš site.js duomenų.
const seoTitle = `${imone.pavadinimas} — ${paslaugos.map((p) => p.pavadinimas).join(', ')} ${imone.miestas}`;
const seoDesc = `${paslaugos.map((p) => p.pavadinimas).join(', ')} ${imone.miestas} mieste ir ${imone.aptarnavimoSpindulys}. ${imone.patirtisMetais} m. patirtis. Skambinkite ${imone.telefonas}.`;
---

<Base title={seoTitle} description={seoDesc}>
  <!-- HERO -->
  <section class="relative flex min-h-[92vh] items-center overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true">
      <img src={turinys.hero.nuotrauka} alt="" class="kenburns h-full w-full object-cover" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-950/85 via-brand-950/60 to-brand-950/30"></div>
    </div>

    <div class="relative mx-auto grid w-full max-w-7xl gap-10 px-4 pb-16 pt-44 sm:px-6 lg:grid-cols-[1.2fr_1fr] lg:items-center">
      <div data-reveal>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold text-white backdrop-blur-sm">
          <svg class="h-4 w-4 text-accent" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.783 1.401 8.168L12 19.318l-7.335 3.843 1.401-8.168L.132 9.21l8.2-1.192L12 .587z"/></svg>
          {imone.ivertinimas.toFixed(1)} įvertinimas · {imone.patirtisMetais} m. patirtis
        </span>
        <h1 class="display mt-6 text-4xl font-bold text-white sm:text-5xl lg:text-6xl">
          {turinys.hero.antraste}
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/85">
          {turinys.hero.paantraste}
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="/kontaktai" class="rounded-lg bg-accent px-7 py-4 text-center text-lg font-bold text-brand-950 transition-colors duration-200 hover:bg-accent-dark">
            Gauti nemokamą pasiūlymą
          </a>
          <a href={imone.telefonasHref} class="flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-7 py-4 text-lg font-bold text-white backdrop-blur-sm transition-colors duration-200 hover:bg-white/10">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
            {imone.telefonas}
          </a>
        </div>
      </div>

      <div class="rounded-2xl bg-white/95 p-7 shadow-2xl backdrop-blur-sm" data-reveal style="--d:150ms">
        <h2 class="display text-2xl font-semibold text-brand-950">Gaukite kainą greitai</h2>
        <p class="mb-5 mt-1.5 text-sm text-brand-900/70">Užpildykite formą — susisieksime ir pateiksime pasiūlymą.</p>
        <InquiryForm compact />
      </div>
    </div>
  </section>

  <!-- PASITIKĖJIMO JUOSTA -->
  <section class="border-b border-brand-100 bg-white py-12">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-8 px-4 text-center sm:px-6 lg:grid-cols-4">
      <div data-reveal>
        <p class="display text-4xl font-bold text-brand-700"><span data-countup={String(imone.patirtisMetais)}>0</span>+</p>
        <p class="mt-1.5 text-sm font-medium text-brand-900/70">metų patirtis</p>
      </div>
      <div data-reveal style="--d:80ms">
        <p class="display text-4xl font-bold text-brand-700"><span data-countup={imone.ivertinimas.toFixed(1)}>0</span></p>
        <p class="mt-1.5 text-sm font-medium text-brand-900/70">įvertinimas iš 5</p>
      </div>
      <div data-reveal style="--d:160ms">
        <p class="display text-4xl font-bold text-brand-700"><span data-countup={String(imone.atsiliepimuSkaicius)}>0</span>+</p>
        <p class="mt-1.5 text-sm font-medium text-brand-900/70">klientų atsiliepimų</p>
      </div>
      <div data-reveal style="--d:240ms">
        <p class="display text-4xl font-bold text-brand-700">SF</p>
        <p class="mt-1.5 text-sm font-medium text-brand-900/70">išrašome sąskaitas faktūras</p>
      </div>
    </div>
  </section>

  <!-- APIE MUS -->
  <section class="py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="relative" data-reveal>
        <img src={turinys.apie.nuotrauka} alt={`${imone.pavadinimas} darbų akimirka`} loading="lazy" class="aspect-[4/5] w-full rounded-2xl object-cover shadow-lg" />
        <div class="absolute -bottom-5 -right-3 rounded-xl bg-brand-700 px-6 py-4 text-white shadow-lg sm:-right-6">
          <p class="display text-3xl font-bold">{imone.patirtisMetais} m.</p>
          <p class="text-sm text-white/80">patirties</p>
        </div>
      </div>
      <div data-reveal style="--d:120ms">
        <SectionHeading eyebrow="Apie mus" title={turinys.apie.antraste} center={false} />
        {turinys.apie.pastraipos.map((p) => (
          <p class="mt-6 leading-relaxed text-brand-900/80">{p}</p>
        ))}
        <ul class="mt-6 space-y-3">
          {turinys.apie.privalumai.map((t) => (
            <li class="flex items-center gap-3 font-medium text-brand-950">
              <svg class="h-5 w-5 shrink-0 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
              {t}
            </li>
          ))}
        </ul>
        <a href="/apie-mus" class="mt-7 inline-block rounded-lg bg-brand-700 px-6 py-3 font-bold text-white transition-colors duration-200 hover:bg-brand-800">
          Daugiau apie mus
        </a>
      </div>
    </div>
  </section>

  <!-- PASLAUGOS -->
  <section class="bg-brand-50 py-20" id="paslaugos">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <SectionHeading eyebrow="Paslaugos" title="Ką galime jums padėti" />
      <div class="mt-14 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {paslaugos.map((p, i) => (
          <a
            href={`/paslaugos/${p.slug}`}
            class="group overflow-hidden rounded-2xl bg-white shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl"
            data-reveal
            style={`--d:${i * 90}ms`}
          >
            <div class="overflow-hidden">
              <img src={p.kortelesNuotrauka} alt={p.alt} loading="lazy" class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105" />
            </div>
            <div class="p-6">
              <p class="text-xs font-bold uppercase tracking-widest text-accent-dark">{p.kaina}</p>
              <h3 class="display mt-2 text-xl font-semibold text-brand-950">{p.pavadinimas}</h3>
              <p class="mt-2 text-sm leading-relaxed text-brand-900/70">{p.trumpai}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-brand-700 transition-colors duration-200 group-hover:text-brand-900">
                Plačiau
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              </span>
            </div>
          </a>
        ))}
        <div class="flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-brand-200 p-8 text-center" data-reveal style={`--d:${paslaugos.length * 90}ms`}>
          <h3 class="display text-xl font-semibold text-brand-950">Nerandate, ko ieškote?</h3>
          <p class="mt-2 text-sm text-brand-900/70">Atliekame ir kitus darbus — paskambinkite ir aptarsime.</p>
          <a href={imone.telefonasHref} class="mt-4 rounded-lg bg-brand-700 px-5 py-2.5 text-sm font-bold text-white transition-colors duration-200 hover:bg-brand-800">{imone.telefonas}</a>
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps />

  <!-- GALERIJOS PERŽIŪRA -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <SectionHeading eyebrow="Mūsų darbai" title="Rezultatai kalba patys už save" />
      <div class="mt-12">
        <GalleryGrid nuotraukos={galerijosPavyzdziai} />
      </div>
      <div class="mt-10 text-center" data-reveal>
        <a href="/galerija" class="inline-block rounded-lg bg-brand-700 px-8 py-3.5 font-bold text-white transition-colors duration-200 hover:bg-brand-800">
          Žiūrėti visus darbus
        </a>
      </div>
    </div>
  </section>

  <Reviews />

  <Faq />

  <!-- APTARNAUJAMOS VIETOVĖS -->
  <section class="bg-brand-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <SectionHeading eyebrow="Kur dirbame" title="Aptarnaujamos vietovės" />
      <div class="mt-12 grid items-center gap-10 lg:grid-cols-2">
        <div class="overflow-hidden rounded-2xl shadow-md" data-reveal>
          {/* PAKEISTI žemėlapio bbox/marker pagal kliento miestą (openstreetmap.org → Export). */}
          <iframe
            src="https://www.openstreetmap.org/export/embed.html?bbox=21.0%2C54.5%2C26.5%2C56.5&layer=mapnik&marker=55.0%2C23.8"
            class="h-80 w-full border-0 sm:h-96"
            title={`Aptarnaujamos teritorijos žemėlapis — ${imone.miestas}`}
            loading="lazy"
          ></iframe>
        </div>
        <div data-reveal style="--d:120ms">
          <p class="leading-relaxed text-brand-900/80">
            Bazuojamės {imone.miestas} mieste ir atvykstame {imone.aptarnavimoSpindulys}. Dažniausiai dirbame šiose vietovėse:
          </p>
          <ul class="mt-6 grid grid-cols-2 gap-3">
            {vietoves.map((v) => (
              <li class="flex items-center gap-2.5 font-medium text-brand-950">
                <svg class="h-4 w-4 shrink-0 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                {v}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</Base>
