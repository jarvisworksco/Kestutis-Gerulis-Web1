---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaSection from '../components/CtaSection.astro';
import Reviews from '../components/Reviews.astro';
import { imone, turinys, galerija } from '../data/site.js';

// PAKEISTI vertybes pagal nišą (4 vnt.).
const vertybes = [
  { pavadinimas: 'Atsakingas darbas', aprasymas: 'Dirbame atsakingai, laikomės terminų ir užtikriname sklandų bendradarbiavimą nuo pirmo skambučio iki darbų pabaigos.' },
  { pavadinimas: 'Profesionali įranga', aprasymas: 'Naudojame profesionalią įrangą, kuri leidžia atlikti darbus greitai, kokybiškai ir net sudėtingomis sąlygomis.' },
  { pavadinimas: 'Aiški kaina', aprasymas: 'Kaina priklauso nuo darbo apimties ir sudėtingumo — visada pateikiame ją iš anksto, be paslėptų mokesčių.' },
  { pavadinimas: 'Skaidrumas', aprasymas: 'Išrašome sąskaitas faktūras — patogu ir privatiems klientams, ir įmonėms.' },
];

// Pirmosios 4 galerijos nuotraukos „apie mus" koliažui.
const koliazas = galerija.slice(0, 4);
---

<Base
  title={`Apie mus — ${imone.pavadinimas} | ${imone.patirtisMetais} metų patirtis`}
  description={`${imone.pavadinimas} — ${imone.miestas} įmonė su ${imone.patirtisMetais} metų patirtimi. ${imone.ivertinimas.toFixed(1)} įvertinimas, profesionali įranga, sąskaitos faktūros.`}
>
  <section class="bg-brand-950 pb-16 pt-44">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6" data-reveal>
      <span class="inline-block rounded-full bg-white/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-accent">Apie mus</span>
      <h1 class="display mt-4 text-4xl font-bold text-white sm:text-5xl">Pažinkite {imone.pavadinimas}</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/75">
        {imone.patirtisMetais} metų patirtis · {imone.miestas} ir {imone.aptarnavimoSpindulys}.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div data-reveal>
        <SectionHeading eyebrow="Mūsų istorija" title={turinys.apie.antraste} center={false} />
        {turinys.apie.pastraipos.map((p) => (
          <p class="mt-6 leading-relaxed text-brand-900/80">{p}</p>
        ))}
        {imone.atsiliepimuSkaicius > 0 && (
          <p class="mt-4 leading-relaxed text-brand-900/80">
            Klientų pasitikėjimą patvirtina {imone.ivertinimas.toFixed(1)} įvertinimas iš {imone.atsiliepimuSkaicius} atsiliepimų.
          </p>
        )}
      </div>
      <div class="grid grid-cols-2 gap-4" data-reveal style="--d:120ms">
        {koliazas.map((n, i) => (
          <img src={n.src} alt={n.alt} loading="lazy" class={`aspect-[3/4] w-full rounded-2xl object-cover shadow-md ${i % 2 ? 'mt-8' : ''}`} />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brand-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <SectionHeading eyebrow="Vertybės" title="Kodėl klientai renkasi mus" />
      <div class="mt-14 grid gap-7 sm:grid-cols-2 lg:grid-cols-4">
        {vertybes.map((v, i) => (
          <div class="rounded-2xl bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md" data-reveal style={`--d:${i * 90}ms`}>
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            </span>
            <h3 class="display mt-5 text-lg font-semibold text-brand-950">{v.pavadinimas}</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-900/70">{v.aprasymas}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Reviews />

  <CtaSection />
</Base>
